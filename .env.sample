# PostgreSQL (read by os.environ["PGHOST"], PGDATABASE, PGUSER, PGPASSWORD; PGPORT optional)
PGHOST=
PGDATABASE=
PGUSER=
PGPASSWORD=
PGPORT=

PRIMARY_LLM_MODEL=
PRIMARY_LLM_KEY=
# Hugging Face Inference Providers route (auto picks a live provider for the model)
PRIMARY_LLM_PROVIDER=auto

EMBEDDING_MODEL=
EMBEDDING_MODEL_KEY=

# backend/main.py
QUERY_TOP_K=5
CHAT_HISTORY_MAX_TOKENS=3000

# corpus/ingest/crawl.py (max total sources: GitHub readme-linked files + seed URLs)
CRAWL_MAX_PAGES=400
CRAWL_REQUEST_TIMEOUT_S=30.0
CRAWL_DELAY_S=0.4
CRAWL_USER_AGENT="chat_mvp-ingest/0.1 (+local crawl; contact: project owner)"

# corpus/ingest/chunking.py (~500 tokens at ~4 chars/token; overlap spans boundaries)
CHUNK_MAX_CHARS=2000
CHUNK_OVERLAP_CHARS=200